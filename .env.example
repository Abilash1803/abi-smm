# Environment Variables for SocialBoost App

# API Configuration
# Replace with your actual backend API URL
VITE_API_URL=http://localhost:3001/api

# Development Settings
VITE_DEBUG=true

# Note: In Vite, environment variables must be prefixed with VITE_ to be accessible in the browser
# Example: VITE_API_URL will be available as import.meta.env.VITE_API_URL